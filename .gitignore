# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# Test / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editor / OS
.idea/
.vscode/
.DS_Store

# Audio files (keep directory structure with .gitkeep)
audio/voice/*
audio/bgm/*
audio/outro/*
!audio/*/.gitkeep

# Generated audio output (keep output/.gitkeep)
output/*.mp3
output/*.wav
